# ── AI reasoning engine (Gemma 4 on Cerebras) ───────────────────────────────
# Primary: Cerebras Inference. Get a key at https://cloud.cerebras.ai
CEREBRAS_API_KEY=
# Model served by Cerebras for HeadsUp (override if your account uses another).
GEMMA_MODEL=gemma-3-12b-it

# ── HydraDB threat memory ───────────────────────────────────────────────────
# Long-term cloud memory (usecortex HydraDB). When both API key + tenant are set,
# every event is ingested into HydraDB with structured tenant_metadata
# (see hydradb.tenant-schema.json). SQLite stays the local store + offline fallback.
HYDRADB_API_KEY=
HYDRADB_TENANT_ID=
# Optional: organize this machine's data under a sub-tenant (e.g. host name).
HYDRADB_SUB_TENANT_ID=
# Override only for self-hosted HydraDB.
HYDRADB_API_BASE=https://api.hydradb.com

# Local structured store: default is SQLite at ~/.headsup/headsup.db (zero setup).
# To use Hydra / Postgres instead, set a connection URL (needs `pip install
# headsup[postgres]`), e.g. postgresql://user:pass@localhost:5432/headsup
HYDRA_URL=

# ── Anakin AI-powered web search / threat intelligence ──────────────────────
# Powers live threat-intel ingestion and the copilot "search …" command.
# Without a key, HeadsUp ingests a bundled sample feed of recent campaigns.
ANAKIN_API_KEY=
# Anakin web-search endpoint (auth via X-API-Key header).
ANAKIN_API_URL=https://api.anakin.io/v1/search

# ── Telegram alerts ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Set to 0 to disable the demo/mock alert scheduler.
TELEGRAM_MOCK_ENABLED=1
