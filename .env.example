# ─────────────────────────────────────────────────────────────────────────────
#  HeadsUp configuration. Copy to `.env` and fill in what you have.
#  Everything is optional — HeadsUp runs fully offline with sensible fallbacks.
# ─────────────────────────────────────────────────────────────────────────────

# ── AI reasoning engine (Gemma 4 on Cerebras) ───────────────────────────────
# Primary: Cerebras Inference. Get a key at https://cloud.cerebras.ai
CEREBRAS_API_KEY=
# Model served by Cerebras for HeadsUp (override if your account uses another).
GEMMA_MODEL=gemma-3-12b-it

# Fallback reasoning provider if no Cerebras key is set.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── HydraDB threat memory ───────────────────────────────────────────────────
# Default: local SQLite at ~/.headsup/headsup.db (zero setup).
# To use Hydra / Postgres instead, set a connection URL (needs `pip install
# headsup[postgres]`), e.g. postgresql://user:pass@localhost:5432/headsup
HYDRA_URL=

# ── Anakin threat intelligence ──────────────────────────────────────────────
# Without a key, HeadsUp ingests a bundled sample feed of recent campaigns.
ANAKIN_API_KEY=
# Override only if your Anakin deployment uses a custom endpoint.
ANAKIN_API_URL=https://api.anakin.ai/v1/threat-intel

# ── Telegram alerts (optional) ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Set to 0 to disable the demo/mock alert scheduler.
TELEGRAM_MOCK_ENABLED=1
