# LLM Configuration
LITELLM_MODEL_FAST=openai/claude-haiku-4-5
LITELLM_MODEL_REASONING=openai/claude-sonnet-4-5

LLM_PROVIDER=litellm
LLM_BASE_URL=https://your-llm-proxy.example.com/
LLM_API_KEY=sk-your-api-key-here-api-key-here

# Slack Configuration
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_CHANNEL_ID=C-your-channel-id
SLACK_APP_TOKEN=xapp-your-app-token

# Kubernetes
KUBECONFIG=~/.kube/config
NAMESPACE=k8swhisperer-demo

# Blockchain (optional, 25 bonus marks)
STELLAR_SECRET_KEY=S...
STELLAR_CONTRACT_ID=C...
STELLAR_NETWORK=testnet

# Prometheus (optional, bonus marks)
PROMETHEUS_URL=http://localhost:9090

# Feature Flags
ENABLE_PREDICTIVE_ALERTING=true
ENABLE_RUNBOOK_CACHE=true
ENABLE_MULTI_AGENT=true
ENABLE_BLOCKCHAIN=true
